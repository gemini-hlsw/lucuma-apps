use flake
layout node
eval "$shellHook"

export SOPS_AGE_KEY_FILE="$(pwd)/apps-keys.txt"

watch_file secrets.yaml
if [[ -f secrets.yaml ]]; then
  eval "$(sops -d --output-type dotenv secrets.yaml 2>/dev/null)"
fi

# Point pnpm at a file in .direnv  holding the SOPS-decrypted token.
npmrc="$(direnv_layout_dir)/fontawesome.npmrc"
printf '//npm.fontawesome.com/:_authToken=%s\n' "$FONTAWESOME_NPM_AUTH_TOKEN" > "$npmrc"
export NPM_CONFIG_USERCONFIG="$npmrc"
